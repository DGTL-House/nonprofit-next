---
import { BOOK_HREF, CTA_PRIMARY } from "../consts";

// Each case card: org header → growth chart → Before/What we did/Result
// journey → metrics → client quote. Numbers mirror the brief's worked example.
const cases = [
  {
    org: "Coastal Animal Rescue",
    niche: "Animal Welfare",
    note: "Regional shelter running adoption and rescue programs.",
    period: "12 months",
    spendFrom: "$800",
    spendTo: "$9,200",
    growth: "11.5×",
    // smooth area path inside a 0..720 x 0..240 viewBox
    chart:
      "M0,210 C120,205 180,196 240,170 C300,146 330,120 400,96 C470,72 520,52 600,36 C650,26 690,20 720,16",
    before:
      "$800/mo spent of $10K. No conversion tracking, no donations coming from ads.",
    didIt:
      "Rebuilt campaign structure. Set up conversion tracking. Expanded keywords 40 → 300+.",
    result:
      "$9,200/mo spent. 47 donations and 23 sign-ups every single month.",
    metrics: [
      { label: "Donations", value: "+47/mo" },
      { label: "Sign-ups", value: "+23/mo" },
    ],
    quote:
      "The audit showed us three things we'd been doing wrong for a year.",
    author: "Sarah Mitchell, Exec Director",
  },
  {
    org: "Education nonprofit",
    niche: "Education",
    note: "Name under NDA — after-school literacy programs.",
    period: "9 months",
    spendFrom: "$1,150",
    spendTo: "$9,800",
    growth: "8.5×",
    chart:
      "M0,206 C110,202 170,190 240,176 C310,162 350,128 420,104 C480,84 520,60 600,40 C650,28 690,22 720,18",
    before:
      "$1,150/mo of the grant used. Broad keywords, low CTR, one click-through risk warning from Google.",
    didIt:
      "Tightened keyword themes, fixed CTR, restructured ad groups, added program-specific landing pages.",
    result:
      "$9,800/mo spent. Steady stream of enrolment inquiries and volunteer sign-ups.",
    metrics: [
      { label: "Enrolment inquiries", value: "+62/mo" },
      { label: "Volunteer sign-ups", value: "+38/mo" },
    ],
    quote:
      "We finally understand where the budget was leaking — and how to plug it.",
    author: "Program Director",
  },
  {
    org: "Refugee support org",
    niche: "Refugee Support",
    note: "Name under NDA — resettlement and legal aid services.",
    period: "12 months",
    spendFrom: "$600",
    spendTo: "$9,500",
    growth: "15.8×",
    chart:
      "M0,214 C120,210 180,202 250,184 C320,166 360,132 430,106 C500,80 540,56 610,38 C660,26 695,20 720,16",
    before:
      "$600/mo of $10K. Account at risk of suspension, almost no donations from ads.",
    didIt:
      "Cleared policy violations, rebuilt account, set up tracking for donations and case referrals.",
    result:
      "$9,500/mo spent. Donations and volunteer applications every week, suspension risk gone.",
    metrics: [
      { label: "Donations", value: "+51/mo" },
      { label: "Volunteer apps", value: "+29/mo" },
    ],
    quote:
      "For the first time the grant is actually bringing people to our door.",
    author: "Head of Development",
  },
];

const niches = [
  "Education",
  "Healthcare",
  "Animal Welfare",
  "Environment",
  "Faith-based",
  "Refugee Support",
  "Mental Health",
  "Arts & Culture",
  "Youth Programs",
  "International Development",
];
---

<!-- Block 2 — Case Studies -->
<section id="case-studies" class="relative py-16 sm:py-24 overflow-hidden bg-[#ffffff]">
  <div class="absolute top-0 left-0 w-[480px] h-[480px] bg-[#aac976]/10 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Headlines -->
    <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16 reveal">
      <p class="text-[#3f5028] font-bold uppercase tracking-widest text-xs sm:text-sm mb-4">
        Case Studies
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-[#161514] leading-tight mb-5">
        Don't believe a grant can hit $10K?
        <span class="gradient-text-lime">Here's how we did it.</span>
      </h2>
      <p class="text-[#52504c] text-base sm:text-xl">
        We've done this before. Real clients · real numbers · real screenshots.
      </p>
    </div>

    <!-- Carousel -->
    <div class="relative reveal">
      <div id="cases-track" class="carousel-track">
        {
          cases.map((c, i) => (
            <article class="carousel-slide">
              <div class="glass-card rounded-3xl p-5 sm:p-7 h-full flex flex-col gap-5 shadow-[0_12px_40px_rgba(63,80,40,0.06)]">
                {/* Org header */}
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <h3 class="text-[#161514] font-bold text-lg sm:text-xl leading-tight">
                      {c.org}
                    </h3>
                    <p class="text-[#7a7770] text-sm mt-1">{c.note}</p>
                  </div>
                  <span class="shrink-0 inline-flex items-center gap-1 text-amber-500" aria-label="5 out of 5 stars">
                    {[0, 1, 2, 3, 4].map(() => (
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="#aac976" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" /></svg>
                    ))}
                  </span>
                </div>

                <div class="flex flex-wrap items-center gap-2">
                  <span class="px-3 py-1 rounded-full bg-[#eaf6cc] text-[#3f5028] text-xs font-semibold">
                    {c.niche}
                  </span>
                  <span class="text-[#9a9890] text-xs font-medium">
                    Clutch · {c.period}
                  </span>
                </div>

                {/* Growth chart (click to enlarge) */}
                <button
                  class="case-chart group relative block w-full rounded-2xl bg-[#f6f8ee] border border-[#e7eed5] p-4 text-left"
                  data-org={c.org}
                  data-from={c.spendFrom}
                  data-to={c.spendTo}
                  data-chart={c.chart}
                  aria-label={`Enlarge ${c.org} Google Ads spend chart`}
                >
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-[11px] font-semibold uppercase tracking-wide text-[#7a7770]">
                      Google Ads · monthly spend, {c.period}
                    </span>
                    <span class="w-7 h-7 rounded-lg bg-[#161514]/70 text-white flex items-center justify-center opacity-80 group-hover:opacity-100 transition-opacity">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>
                    </span>
                  </div>
                  <svg viewBox="0 0 720 240" class="w-full h-32 sm:h-40" preserveAspectRatio="none" aria-hidden="true">
                    <defs>
                      <linearGradient id={`area-${i}`} x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#aac976" stop-opacity="0.35" />
                        <stop offset="100%" stop-color="#aac976" stop-opacity="0.03" />
                      </linearGradient>
                    </defs>
                    <path d={`${c.chart} L720,240 L0,240 Z`} fill={`url(#area-${i})`} />
                    <path d={c.chart} fill="none" stroke="#3f7d4f" stroke-width="3.5" stroke-linecap="round" />
                  </svg>
                  <div class="flex items-center justify-between mt-1">
                    <span class="text-[#b33d27] text-sm font-bold">{c.spendFrom}</span>
                    <span class="text-[#3f5028] text-base sm:text-lg font-extrabold">{c.spendTo}</span>
                  </div>
                </button>

                {/* Budget utilisation badge */}
                <div class="rounded-2xl bg-[#eef5e0] text-center py-3">
                  <div class="text-[11px] font-semibold uppercase tracking-wide text-[#7a7770]">
                    Budget utilisation
                  </div>
                  <div class="text-2xl font-black text-[#3f5028]">{c.growth} growth</div>
                </div>

                {/* Horizontal journey: Before / What we did / Result */}
                <div class="grid sm:grid-cols-3 gap-3">
                  <div class="rounded-xl p-3.5 bg-[rgba(179,61,39,0.06)] border border-[rgba(179,61,39,0.14)]">
                    <div class="flex items-center gap-2 mb-1.5">
                      <span class="w-5 h-5 rounded-full bg-[rgba(179,61,39,0.14)] text-[#b33d27] flex items-center justify-center text-[11px] font-black">1</span>
                      <span class="text-[#b33d27] font-bold text-sm">Before</span>
                    </div>
                    <p class="text-[#52504c] text-[13px] leading-snug">{c.before}</p>
                  </div>
                  <div class="rounded-xl p-3.5 bg-[#f0eee6] border border-[#e4e1d6]">
                    <div class="flex items-center gap-2 mb-1.5">
                      <span class="w-5 h-5 rounded-full bg-[#e0ddcf] text-[#3f5028] flex items-center justify-center text-[11px] font-black">2</span>
                      <span class="text-[#3f5028] font-bold text-sm">What we did</span>
                    </div>
                    <p class="text-[#52504c] text-[13px] leading-snug">{c.didIt}</p>
                  </div>
                  <div class="rounded-xl p-3.5 bg-[rgba(170,201,118,0.16)] border border-[rgba(170,201,118,0.4)]">
                    <div class="flex items-center gap-2 mb-1.5">
                      <span class="w-5 h-5 rounded-full bg-[rgba(170,201,118,0.4)] text-[#3f5028] flex items-center justify-center text-[11px] font-black">3</span>
                      <span class="text-[#3f5028] font-bold text-sm">Result</span>
                    </div>
                    <p class="text-[#52504c] text-[13px] leading-snug">{c.result}</p>
                  </div>
                </div>

                {/* Metrics */}
                <div class="grid grid-cols-2 gap-3">
                  {c.metrics.map((m) => (
                    <div class="rounded-xl bg-[#f8f7f3] border border-[#ebe9e0] py-3 text-center">
                      <div class="text-[11px] font-semibold uppercase tracking-wide text-[#7a7770]">
                        {m.label}
                      </div>
                      <div class="text-xl font-black text-[#3f5028]">{m.value}</div>
                    </div>
                  ))}
                </div>

                {/* Client quote */}
                <figure class="mt-auto border-t border-[#ebe9e0] pt-4">
                  <blockquote class="text-[#161514] text-sm sm:text-base italic leading-relaxed">
                    “{c.quote}”
                  </blockquote>
                  <figcaption class="text-[#7a7770] text-xs sm:text-sm mt-2">
                    — {c.author}
                  </figcaption>
                </figure>
              </div>
            </article>
          ))
        }
      </div>

      <!-- Arrows -->
      <button
        id="cases-prev"
        aria-label="Previous case study"
        class="hidden sm:flex absolute -left-4 lg:-left-6 top-1/2 -translate-y-1/2 w-11 h-11 rounded-full bg-[#ffffff] border border-[#ebe9e0] shadow-md items-center justify-center text-[#3f5028] hover:bg-[#f0eee6] transition-colors z-10"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button
        id="cases-next"
        aria-label="Next case study"
        class="hidden sm:flex absolute -right-4 lg:-right-6 top-1/2 -translate-y-1/2 w-11 h-11 rounded-full bg-[#ffffff] border border-[#ebe9e0] shadow-md items-center justify-center text-[#3f5028] hover:bg-[#f0eee6] transition-colors z-10"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>

    <!-- Dots -->
    <div id="cases-dots" class="flex items-center justify-center gap-2 mt-6">
      {cases.map((_, i) => (
        <button class="carousel-dot" data-dot={i} aria-label={`Go to case ${i + 1}`} aria-current={i === 0 ? "true" : "false"}></button>
      ))}
    </div>

    <!-- Niche pill-tags -->
    <div class="mt-12 reveal">
      <p class="text-center text-[#7a7770] text-sm font-medium mb-4">
        Audited and scaled across every kind of mission:
      </p>
      <div class="flex flex-wrap justify-center gap-2.5 max-w-3xl mx-auto">
        {
          niches.map((n) => (
            <span class="px-4 py-2 rounded-full bg-[#aac976]/10 border border-[#aac976]/25 text-[#3f5028] text-sm font-medium">
              {n}
            </span>
          ))
        }
      </div>
    </div>

    <div class="flex justify-center mt-12">
      <a href={BOOK_HREF} class="btn-primary text-base sm:text-2xl !py-3 sm:!py-4 !px-8 sm:!px-10">
        {CTA_PRIMARY} →
      </a>
    </div>
  </div>
</section>

<!-- Lightbox -->
<div id="case-lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Enlarged spend chart">
  <div class="relative w-full max-w-3xl bg-[#ffffff] rounded-2xl p-5 sm:p-7">
    <button id="lightbox-close" aria-label="Close" class="absolute top-3 right-3 w-9 h-9 rounded-full bg-[#f0eee6] text-[#161514] flex items-center justify-center hover:bg-[#ebe9e0]">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
    <div id="lightbox-title" class="text-[#161514] font-bold text-lg mb-1"></div>
    <div class="text-[11px] font-semibold uppercase tracking-wide text-[#7a7770] mb-3">
      Google Ads · monthly spend
    </div>
    <svg id="lightbox-svg" viewBox="0 0 720 240" class="w-full h-56 sm:h-72" preserveAspectRatio="none" aria-hidden="true">
      <defs>
        <linearGradient id="area-lb" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#aac976" stop-opacity="0.35"></stop>
          <stop offset="100%" stop-color="#aac976" stop-opacity="0.03"></stop>
        </linearGradient>
      </defs>
      <path id="lightbox-area" d="" fill="url(#area-lb)"></path>
      <path id="lightbox-line" d="" fill="none" stroke="#3f7d4f" stroke-width="3.5" stroke-linecap="round"></path>
    </svg>
    <div class="flex items-center justify-between mt-2">
      <span id="lightbox-from" class="text-[#b33d27] text-base font-bold"></span>
      <span id="lightbox-to" class="text-[#3f5028] text-xl font-extrabold"></span>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const track = document.getElementById("cases-track");
    if (!track) return;
    const slides = Array.prototype.slice.call(
      track.querySelectorAll(".carousel-slide"),
    );
    const dots = Array.prototype.slice.call(
      document.querySelectorAll("[data-dot]"),
    );
    const prev = document.getElementById("cases-prev");
    const next = document.getElementById("cases-next");

    function current() {
      let idx = 0;
      let min = Infinity;
      slides.forEach(function (s, i) {
        const d = Math.abs(
          s.getBoundingClientRect().left - track.getBoundingClientRect().left,
        );
        if (d < min) {
          min = d;
          idx = i;
        }
      });
      return idx;
    }
    function sync() {
      const idx = current();
      dots.forEach(function (d, i) {
        d.setAttribute("aria-current", i === idx ? "true" : "false");
      });
    }
    function go(idx) {
      const i = Math.max(0, Math.min(slides.length - 1, idx));
      track.scrollTo({ left: slides[i].offsetLeft - track.offsetLeft, behavior: "smooth" });
    }
    track.addEventListener("scroll", function () {
      window.requestAnimationFrame(sync);
    }, { passive: true });
    prev && prev.addEventListener("click", function () { go(current() - 1); });
    next && next.addEventListener("click", function () { go(current() + 1); });
    dots.forEach(function (d, i) {
      d.addEventListener("click", function () { go(i); });
    });
    sync();

    // Lightbox
    const lb = document.getElementById("case-lightbox");
    const lbArea = document.getElementById("lightbox-area");
    const lbLine = document.getElementById("lightbox-line");
    const lbTitle = document.getElementById("lightbox-title");
    const lbFrom = document.getElementById("lightbox-from");
    const lbTo = document.getElementById("lightbox-to");
    function openLb(btn) {
      const chart = btn.getAttribute("data-chart");
      lbArea.setAttribute("d", chart + " L720,240 L0,240 Z");
      lbLine.setAttribute("d", chart);
      lbTitle.textContent = btn.getAttribute("data-org");
      lbFrom.textContent = btn.getAttribute("data-from");
      lbTo.textContent = btn.getAttribute("data-to");
      lb.classList.add("is-open");
      document.body.style.overflow = "hidden";
    }
    function closeLb() {
      lb.classList.remove("is-open");
      document.body.style.overflow = "";
    }
    document.querySelectorAll(".case-chart").forEach(function (btn) {
      btn.addEventListener("click", function () { openLb(btn); });
    });
    document.getElementById("lightbox-close").addEventListener("click", closeLb);
    lb.addEventListener("click", function (e) { if (e.target === lb) closeLb(); });
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeLb();
    });
  })();
</script>
