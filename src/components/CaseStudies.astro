---
import { BOOK_HREF, CTA_PRIMARY } from "../consts";

// Each case card: org header → growth chart → Before/What we did/Result
// journey → metrics → client quote. Numbers mirror the brief's worked example.
const cases = [
  {
    org: "Refugee support org",
    niche: "Refugee Support",
    note: "Name under NDA — resettlement and legal aid services.",
    period: "",
    spendFrom: "$200",
    spendTo: "$7,600",
    budget: "$0 → $7,600/mo",
    img: "/img/case_1.png",
    // smooth area path inside a 0..720 x 0..240 viewBox
    chart:
      "M0,214 C120,210 180,202 250,184 C320,166 360,132 430,106 C500,80 540,56 610,38 C660,26 695,20 720,16",
    before:
      "$200/mo of $10K. Account at risk of suspension, almost no donations from ads.",
    didIt:
      "Cleared policy violations, rebuilt account, set up tracking for donations and case referrals.",
    result:
      "$7,600/mo spent. Donations and volunteer applications every week, suspension risk gone.",
    metrics: [
      { label: "Donations", value: "+51/mo" },
      { label: "Volunteer apps", value: "+29/mo" },
    ],
    quote:
      "For the first time the grant is actually bringing people to our door.",
    author: "Head of Development",
  },
  {
    org: "Education nonprofit",
    niche: "Education",
    note: "Name under NDA — after-school literacy programs.",
    period: "",
    spendFrom: "$500",
    spendTo: "~$10,000",
    budget: "20× growth",
    img: "/img/case_2.png",
    chart:
      "M0,206 C110,202 170,190 240,176 C310,162 350,128 420,104 C480,84 520,60 600,40 C650,28 690,22 720,18",
    before:
      "Broad keywords, low CTR, one click-through risk warning from Google.",
    didIt:
      "Tightened keyword themes, fixed CTR, restructured ad groups, added program-specific landing pages.",
    result:
      "~$10,000/mo spent. Steady stream of enrolment inquiries and volunteer sign-ups.",
    metrics: [
      { label: "Enrolment inquiries", value: "+62/mo" },
      { label: "Volunteer sign-ups", value: "+38/mo" },
    ],
    quote:
      "We finally understand where the budget was leaking — and how to plug it.",
    author: "Program Director",
  },
  {
    org: "Coastal Animal Rescue",
    niche: "Animal Welfare",
    note: "Regional shelter running adoption and rescue programs.",
    period: "",
    spendFrom: "$0",
    spendTo: "~$10,000",
    budget: "$0 → ~$10,000/mo",
    img: "/img/case_3.png",
    chart:
      "M0,210 C120,205 180,196 240,170 C300,146 330,120 400,96 C470,72 520,52 600,36 C650,26 690,20 720,16",
    before:
      "No Google Ad Grant. No Google Ads account. Zero grant-funded traffic.",
    didIt:
      "Secured the Google Ad Grant, built the account from scratch, and scaled campaigns to maximise budget utilisation.",
    result:
      "~$10,000/mo consistently spent. A steady flow of donations and volunteer sign-ups every month.",
    metrics: [
      { label: "Donations", value: "+82/mo" },
      { label: "Volunteer sign-ups", value: "+64/mo" },
    ],
    quote:
      "We didn't even know we qualified for the grant — now it runs our adoption campaigns every month.",
    author: "Sarah Mitchell, Exec Director",
  },
  {
    org: "Youth mentorship org",
    niche: "Youth Programs",
    note: "Name under NDA — started with no Google Ad Grant.",
    period: "",
    spendFrom: "$0",
    spendTo: "~$10,000",
    budget: "~100%",
    img: "/img/case_4.png",
    chart:
      "M0,224 C130,222 200,216 270,196 C340,176 380,140 450,110 C520,80 560,52 620,36 C665,24 695,18 720,15",
    before:
      "No Google Ad Grant. No Google Ads account. Zero grant-funded traffic.",
    didIt:
      "Secured the Google Ad Grant, built the account, and optimised campaigns for maximum budget utilisation.",
    result:
      "~$10,000/mo consistently spent with a steady flow of donations and volunteer sign-ups.",
    metrics: [
      { label: "Donations", value: "+54/mo" },
      { label: "Contact requests", value: "+46/mo" },
    ],
    quote:
      "We went from no ads at all to a full grant working for us every month.",
    author: "Executive Director",
  },
];

const niches = [
  "Education",
  "Healthcare",
  "Animal Welfare",
  "Environment",
  "Faith-based",
  "Refugee Support",
  "Mental Health",
  "Arts & Culture",
  "Youth Programs",
  "International Development",
  "Other",
];
---

<!-- Block 2 — Case Studies -->
<section
  id="case-studies"
  class="relative py-16 sm:py-24 overflow-hidden bg-[#ffffff]"
>
  <div
    class="absolute top-0 left-0 w-[480px] h-[480px] bg-[#aac976]/10 rounded-full blur-[150px] pointer-events-none"
  >
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Headlines -->
    <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16 reveal">
      <p
        class="text-[#3f5028] font-bold uppercase tracking-widest text-xs sm:text-sm mb-4"
      >
        Case Studies
      </p>
      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-black text-[#161514] leading-tight mb-5"
      >
        Don't believe a grant can hit $10K?
        <span class="gradient-text-lime">Here's how we did it.</span>
      </h2>
      <p class="text-[#52504c] text-base sm:text-xl">
        We've done this before. Real clients · real numbers · real screenshots.
      </p>
    </div>

    <!-- Carousel -->
    <div class="relative reveal">
      <div id="cases-track" class="carousel-track">
        {
          cases.map((c) => (
            <article class="carousel-slide">
              <div class="glass-card rounded-3xl p-5 sm:p-7 h-full flex flex-col gap-5 shadow-[0_12px_40px_rgba(63,80,40,0.06)]">
                {/* Org header */}
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <h3 class="text-[#161514] font-bold text-lg sm:text-xl leading-tight">
                      {c.org}
                    </h3>
                    <p class="text-[#7a7770] text-sm mt-1">{c.note}</p>
                  </div>
                  <span
                    class="shrink-0 inline-flex items-center gap-1 text-amber-500"
                    role="img"
                    aria-label="5 out of 5 stars"
                  >
                    {[0, 1, 2, 3, 4].map(() => (
                      <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="#EA4335"
                        aria-hidden="true"
                      >
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                      </svg>
                    ))}
                  </span>
                </div>

                <div class="flex flex-wrap items-center gap-2">
                  <span class="px-3 py-1 rounded-full bg-[#eaf6cc] text-[#3f5028] text-xs font-semibold">
                    {c.niche}
                  </span>
                  <span class="text-[#9a9890] text-xs font-medium">
                    Clutch · {c.period}
                  </span>
                </div>

                {/* Real Google Ads screenshot — click to enlarge & zoom */}
                <button
                  class="case-chart group relative block w-full rounded-2xl bg-[#f6f8ee] border border-[#e7eed5] p-3 text-left"
                  data-org={c.org}
                  data-from={c.spendFrom}
                  data-to={c.spendTo}
                  data-img={c.img}
                  aria-label={`Enlarge and zoom the ${c.org} Google Ads screenshot`}
                >
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-[11px] font-semibold uppercase tracking-wide text-[#7a7770]">
                      Google Ads · real account, {c.period}
                    </span>
                    <span class="text-[11px] font-semibold text-[#3f5028]">
                      Verified screenshot
                    </span>
                  </div>

                  {/* Screenshot with a loud zoom affordance overlaid */}
                  <div class="zoom-frame relative aspect-[2/1] rounded-xl overflow-hidden border border-[#e2e6d3] bg-[#ffffff]">
                    <img
                      src={c.img}
                      alt={`${c.org} — Google Ads monthly spend growing to ${c.spendTo}`}
                      loading="lazy"
                      decoding="async"
                      class="w-full h-full object-cover block select-none transition-transform duration-500 group-hover:scale-[1.03]"
                    />

                    {/* Hover/desktop dim + big magnifier */}
                    <div class="absolute inset-0 hidden sm:flex items-center justify-center bg-[#0b1f12]/0 group-hover:bg-[#0b1f12]/35 transition-colors duration-300">
                      <span class="flex items-center gap-2 px-4 py-2.5 rounded-full bg-[#ffffff] text-[#161514] font-bold text-sm shadow-lg opacity-0 scale-90 group-hover:opacity-100 group-hover:scale-100 transition-all duration-300">
                        <svg
                          width="18"
                          height="18"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="#3f5028"
                          stroke-width="2.4"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <circle cx="11" cy="11" r="7" />
                          <line x1="21" y1="21" x2="16.65" y2="16.65" />
                          <line x1="11" y1="8" x2="11" y2="14" />
                          <line x1="8" y1="11" x2="14" y2="11" />
                        </svg>
                        Click to zoom in
                      </span>
                    </div>

                    {/* Always-visible magnifier pill (works on mobile too) */}
                    <span class="zoom-pill absolute bottom-2.5 right-2.5 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-[#161514]/90 text-[#ffffff] text-xs font-bold shadow-md backdrop-blur-sm">
                      <svg
                        width="15"
                        height="15"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="#ffffff"
                        stroke-width="2.4"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <circle cx="11" cy="11" r="7" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                        <line x1="11" y1="8" x2="11" y2="14" />
                        <line x1="8" y1="11" x2="14" y2="11" />
                      </svg>
                      Tap to zoom
                    </span>
                  </div>

                  <div class="flex items-center justify-between mt-2 px-1">
                    <span class="text-[#b33d27] text-sm font-bold">
                      {c.spendFrom}
                    </span>
                    <span class="text-[#3f5028] text-base sm:text-lg font-extrabold">
                      {c.spendTo}
                    </span>
                  </div>
                </button>

                {/* Budget utilisation badge */}
                <div class="rounded-2xl bg-[#eef5e0] text-center py-3">
                  <div class="text-[11px] font-semibold uppercase tracking-wide text-[#7a7770]">
                    Budget utilisation
                  </div>
                  <div class="text-xl sm:text-2xl font-black text-[#3f5028]">
                    {c.budget}
                  </div>
                </div>

                {/* Horizontal journey: Before / What we did / Result */}
                <div class="grid sm:grid-cols-3 gap-3">
                  <div class="rounded-xl p-3.5 bg-[rgba(179,61,39,0.06)] border border-[rgba(179,61,39,0.14)]">
                    <div class="flex items-center gap-2 mb-1.5">
                      <span class="w-5 h-5 rounded-full bg-[rgba(179,61,39,0.14)] text-[#b33d27] flex items-center justify-center text-[11px] font-black">
                        1
                      </span>
                      <span class="text-[#b33d27] font-bold text-sm">
                        Before
                      </span>
                    </div>
                    <p class="text-[#52504c] text-[13px] leading-snug">
                      {c.before}
                    </p>
                  </div>
                  <div class="rounded-xl p-3.5 bg-[#f0eee6] border border-[#e4e1d6]">
                    <div class="flex items-center gap-2 mb-1.5">
                      <span class="w-5 h-5 rounded-full bg-[#e0ddcf] text-[#3f5028] flex items-center justify-center text-[11px] font-black">
                        2
                      </span>
                      <span class="text-[#3f5028] font-bold text-sm">
                        What we did
                      </span>
                    </div>
                    <p class="text-[#52504c] text-[13px] leading-snug">
                      {c.didIt}
                    </p>
                  </div>
                  <div class="rounded-xl p-3.5 bg-[rgba(170,201,118,0.16)] border border-[rgba(170,201,118,0.4)]">
                    <div class="flex items-center gap-2 mb-1.5">
                      <span class="w-5 h-5 rounded-full bg-[rgba(170,201,118,0.4)] text-[#3f5028] flex items-center justify-center text-[11px] font-black">
                        3
                      </span>
                      <span class="text-[#3f5028] font-bold text-sm">
                        Result
                      </span>
                    </div>
                    <p class="text-[#52504c] text-[13px] leading-snug">
                      {c.result}
                    </p>
                  </div>
                </div>

                {/* Metrics */}
                <div class="grid grid-cols-2 gap-3">
                  {c.metrics.map((m) => (
                    <div class="rounded-xl bg-[#f8f7f3] border border-[#ebe9e0] py-3 text-center">
                      <div class="text-[11px] font-semibold uppercase tracking-wide text-[#7a7770]">
                        {m.label}
                      </div>
                      <div class="text-xl font-black text-[#3f5028]">
                        {m.value}
                      </div>
                    </div>
                  ))}
                </div>

                {/* Client quote */}
                <figure class="mt-auto border-t border-[#ebe9e0] pt-4">
                  <blockquote class="text-[#161514] text-sm sm:text-base italic leading-relaxed">
                    “{c.quote}”
                  </blockquote>
                  <figcaption class="text-[#7a7770] text-xs sm:text-sm mt-2">
                    — {c.author}
                  </figcaption>
                </figure>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <!-- Controls: arrows flank the dots on every breakpoint; each arrow fades
         out at its end. Dots are built in JS so their count matches the number
         of reachable scroll pages (2-up desktop yields fewer pages than cards). -->
    <div class="flex items-center justify-center gap-3 sm:gap-4 mt-6">
      <button
        id="cases-prev"
        aria-label="Previous case study"
        class="carousel-arrow w-10 h-10 sm:w-11 sm:h-11 rounded-full bg-[#ffffff] border border-[#ebe9e0] shadow-md flex items-center justify-center text-[#3f5028] hover:bg-[#f0eee6] shrink-0"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg
        >
      </button>

      <div
        id="cases-dots"
        class="flex items-center justify-center gap-2 min-h-[39px]"
        role="tablist"
        aria-label="Case study pages"
      >
      </div>

      <button
        id="cases-next"
        aria-label="Next case study"
        class="carousel-arrow w-10 h-10 sm:w-11 sm:h-11 rounded-full bg-[#ffffff] border border-[#ebe9e0] shadow-md flex items-center justify-center text-[#3f5028] hover:bg-[#f0eee6] shrink-0"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </button>
    </div>

    <!-- Niche pill-tags -->
    <div class="mt-12 reveal">
      <p class="text-center text-[#7a7770] text-sm font-medium mb-4">
        Audited and scaled across every kind of mission:
      </p>
      <div class="flex flex-wrap justify-center gap-2.5 max-w-3xl mx-auto">
        {
          niches.map((n) => (
            <span class="px-4 py-2 rounded-full bg-[#aac976]/10 border border-[#aac976]/25 text-[#3f5028] text-sm font-medium">
              {n}
            </span>
          ))
        }
      </div>
    </div>

    <div class="flex justify-center mt-12">
      <a
        href={BOOK_HREF}
        class="btn-primary text-base sm:text-2xl !py-3 sm:!py-4 !px-8 sm:!px-10"
      >
        {CTA_PRIMARY} →
      </a>
    </div>
  </div>
</section>

<!-- Lightbox -->
<div
  id="case-lightbox"
  class="lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Enlarged spend chart"
>
  <div
    class="relative w-full h-full sm:h-auto sm:max-w-3xl bg-[#ffffff] sm:rounded-2xl p-4 sm:p-7 flex flex-col"
  >
    <button
      id="lightbox-close"
      aria-label="Close"
      class="absolute top-3 right-3 z-10 w-10 h-10 rounded-full bg-[#f0eee6] text-[#161514] flex items-center justify-center hover:bg-[#ebe9e0] shadow-sm"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><line x1="18" y1="6" x2="6" y2="18"></line><line
          x1="6"
          y1="6"
          x2="18"
          y2="18"></line></svg
      >
    </button>
    <div
      id="lightbox-title"
      class="text-[#161514] font-bold text-lg mb-1 pr-12"
    >
    </div>
    <div
      class="text-[11px] font-semibold uppercase tracking-wide text-[#7a7770] mb-3"
    >
      Google Ads · real account screenshot
    </div>

    <!-- Zoomable stage: fills the screen on mobile, fixed height on desktop -->
    <div class="flex-1 min-h-0 flex items-center justify-center">
      <div
        id="lightbox-stage"
        class="lightbox-stage w-full max-h-full overflow-hidden rounded-xl bg-[#ffffff] border border-[#e7eed5] flex items-center justify-center"
      >
        <img
          id="lightbox-img"
          class="lightbox-svg w-full h-auto max-h-full object-contain block select-none"
          alt="Google Ads account screenshot — monthly spend growth"
          draggable="false"
          src=""
        />
      </div>
    </div>

    <div class="flex items-center justify-between mt-3 shrink-0">
      <span id="lightbox-from" class="text-[#b33d27] text-base font-bold"
      ></span>
      <span id="lightbox-to" class="text-[#3f5028] text-xl font-extrabold"
      ></span>
    </div>
    <p class="text-center text-[11px] text-[#9a9890] mt-2 shrink-0">
      <span class="sm:hidden"
        >Pinch to zoom · drag to pan · double-tap to reset</span
      >
      <span class="hidden sm:inline"
        >Scroll to zoom · drag to pan · double-click to reset</span
      >
    </p>
  </div>
</div>

<script is:inline>
  (function () {
    const track = document.getElementById("cases-track");
    if (!track) return;
    const dotsWrap = document.getElementById("cases-dots");
    const prev = document.getElementById("cases-prev");
    const next = document.getElementById("cases-next");

    // A "page" is one viewport-width of the track. The desktop layout shows two
    // cards at once, so there are fewer pages than cards — dots track pages, not
    // cards, otherwise the last dot(s) could never become active.
    let pageCount = 0;

    function computePages() {
      const cw = track.clientWidth;
      if (cw === 0) return 1;
      const maxScroll = track.scrollWidth - cw;
      if (maxScroll <= 1) return 1;
      return Math.max(1, Math.round(maxScroll / cw) + 1);
    }
    function currentPage() {
      const cw = track.clientWidth || 1;
      return Math.max(
        0,
        Math.min(pageCount - 1, Math.round(track.scrollLeft / cw)),
      );
    }
    function go(page) {
      const cw = track.clientWidth;
      const p = Math.max(0, Math.min(pageCount - 1, page));
      track.scrollTo({ left: p * cw, behavior: "smooth" });
    }
    function syncDots() {
      const active = currentPage();
      Array.prototype.forEach.call(dotsWrap.children, function (d, i) {
        d.setAttribute("aria-current", i === active ? "true" : "false");
      });
      // Fade the prev arrow at the start, the next arrow at the end.
      const single = pageCount <= 1;
      if (prev) prev.classList.toggle("is-hidden", single || active <= 0);
      if (next)
        next.classList.toggle("is-hidden", single || active >= pageCount - 1);
    }
    function buildDots() {
      const pages = computePages();
      if (pages !== pageCount || dotsWrap.children.length !== pages) {
        pageCount = pages;
        dotsWrap.innerHTML = "";
        if (pageCount > 1) {
          for (let i = 0; i < pageCount; i++) {
            const b = document.createElement("button");
            b.className = "carousel-dot";
            b.setAttribute("role", "tab");
            b.setAttribute("aria-label", "Go to slide " + (i + 1));
            b.addEventListener(
              "click",
              (function (idx) {
                return function () {
                  go(idx);
                };
              })(i),
            );
            dotsWrap.appendChild(b);
          }
        }
      }
      syncDots();
    }

    track.addEventListener(
      "scroll",
      function () {
        window.requestAnimationFrame(syncDots);
      },
      { passive: true },
    );
    prev &&
      prev.addEventListener("click", function () {
        go(currentPage() - 1);
      });
    next &&
      next.addEventListener("click", function () {
        go(currentPage() + 1);
      });

    let resizeTimer;
    window.addEventListener("resize", function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(buildDots, 150);
    });
    buildDots();

    // Lightbox
    const lb = document.getElementById("case-lightbox");
    const lbTitle = document.getElementById("lightbox-title");
    const lbFrom = document.getElementById("lightbox-from");
    const lbTo = document.getElementById("lightbox-to");
    // --- Pinch / wheel zoom + drag-pan for the enlarged screenshot ---
    const lbStage = document.getElementById("lightbox-stage");
    const lbSvg = document.getElementById("lightbox-img");
    const MIN = 1,
      MAX = 5;
    let scale = 1,
      tx = 0,
      ty = 0;
    const pointers = new Map();
    let pinch = null; // two-finger gesture snapshot
    let panLast = null; // one-finger / mouse pan anchor
    let lastTap = 0;
    let downInfo = null; // single-pointer tap candidate (null during a pinch/drag)

    function rect() {
      return lbStage.getBoundingClientRect();
    }
    function clampPan() {
      const r = rect();
      tx = Math.min(0, Math.max(r.width * (1 - scale), tx));
      ty = Math.min(0, Math.max(r.height * (1 - scale), ty));
    }
    function apply() {
      lbSvg.style.transform =
        "translate(" + tx + "px," + ty + "px) scale(" + scale + ")";
    }
    // Zoom toward a focal client-point, keeping that point visually fixed.
    function zoomTo(next, clientX, clientY, animate) {
      const r = rect();
      const ox = clientX == null ? r.width / 2 : clientX - r.left;
      const oy = clientY == null ? r.height / 2 : clientY - r.top;
      const cx = (ox - tx) / scale,
        cy = (oy - ty) / scale;
      scale = Math.min(MAX, Math.max(MIN, next));
      tx = ox - cx * scale;
      ty = oy - cy * scale;
      clampPan();
      lbSvg.classList.toggle("animate", !!animate);
      apply();
    }
    function reset(animate) {
      scale = 1;
      tx = 0;
      ty = 0;
      lbSvg.classList.toggle("animate", !!animate);
      apply();
    }

    lbStage.addEventListener("pointerdown", function (e) {
      lbStage.setPointerCapture(e.pointerId);
      pointers.set(e.pointerId, { x: e.clientX, y: e.clientY });
      lbSvg.classList.remove("animate");
      if (pointers.size === 2) {
        const p = Array.from(pointers.values());
        pinch = {
          dist: Math.hypot(p[0].x - p[1].x, p[0].y - p[1].y),
          scale: scale,
          tx: tx,
          ty: ty,
          midX: (p[0].x + p[1].x) / 2,
          midY: (p[0].y + p[1].y) / 2,
        };
        downInfo = null; // a pinch is never a tap
      } else {
        panLast = { x: e.clientX, y: e.clientY };
        downInfo = { x: e.clientX, y: e.clientY };
      }
    });

    lbStage.addEventListener("pointermove", function (e) {
      if (!pointers.has(e.pointerId)) return;
      pointers.set(e.pointerId, { x: e.clientX, y: e.clientY });
      if (
        downInfo &&
        Math.hypot(e.clientX - downInfo.x, e.clientY - downInfo.y) > 12
      ) {
        downInfo = null; // moved too far to be a tap
      }
      if (pointers.size === 2 && pinch) {
        const p = Array.from(pointers.values());
        const r = rect();
        const dist = Math.hypot(p[0].x - p[1].x, p[0].y - p[1].y);
        const cx = (pinch.midX - r.left - pinch.tx) / pinch.scale;
        const cy = (pinch.midY - r.top - pinch.ty) / pinch.scale;
        const midX = (p[0].x + p[1].x) / 2 - r.left;
        const midY = (p[0].y + p[1].y) / 2 - r.top;
        scale = Math.min(MAX, Math.max(MIN, pinch.scale * (dist / pinch.dist)));
        tx = midX - cx * scale;
        ty = midY - cy * scale;
        clampPan();
        apply();
      } else if (pointers.size === 1 && panLast && scale > 1) {
        lbStage.classList.add("is-panning");
        tx += e.clientX - panLast.x;
        ty += e.clientY - panLast.y;
        panLast = { x: e.clientX, y: e.clientY };
        clampPan();
        apply();
      }
    });

    function endPointer(e) {
      pointers.delete(e.pointerId);
      lbStage.classList.remove("is-panning");
      if (pointers.size < 2) pinch = null;
      const left = Array.from(pointers.values())[0];
      panLast = left ? { x: left.x, y: left.y } : null;
    }
    lbStage.addEventListener("pointerup", function (e) {
      // Only a genuine single-finger tap (not the tail of a pinch/drag) counts
      // toward the double-tap-to-reset gesture.
      const isTap =
        downInfo &&
        pointers.size === 1 &&
        Math.hypot(e.clientX - downInfo.x, e.clientY - downInfo.y) < 12;
      if (isTap) {
        const now = Date.now();
        if (now - lastTap < 300) {
          if (scale > 1.05) reset(true);
          else zoomTo(2.5, e.clientX, e.clientY, true);
          lastTap = 0;
        } else {
          lastTap = now;
        }
      }
      downInfo = null;
      endPointer(e);
    });
    lbStage.addEventListener("pointercancel", endPointer);
    lbStage.addEventListener(
      "wheel",
      function (e) {
        e.preventDefault();
        zoomTo(
          scale * (e.deltaY < 0 ? 1.15 : 1 / 1.15),
          e.clientX,
          e.clientY,
          false,
        );
      },
      { passive: false },
    );

    function openLb(btn) {
      lbSvg.setAttribute("src", btn.getAttribute("data-img"));
      lbTitle.textContent = btn.getAttribute("data-org");
      lbFrom.textContent = btn.getAttribute("data-from");
      lbTo.textContent = btn.getAttribute("data-to");
      reset(false);
      lb.classList.add("is-open");
      document.body.style.overflow = "hidden";
    }
    function closeLb() {
      lb.classList.remove("is-open");
      document.body.style.overflow = "";
      pointers.clear();
      pinch = null;
      panLast = null;
      reset(false);
    }
    document.querySelectorAll(".case-chart").forEach(function (btn) {
      btn.addEventListener("click", function () {
        openLb(btn);
      });
    });
    document
      .getElementById("lightbox-close")
      .addEventListener("click", closeLb);
    lb.addEventListener("click", function (e) {
      if (e.target === lb) closeLb();
    });
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeLb();
    });
  })();
</script>
