---
import { BOOK_HREF, CTA_PRIMARY } from "../consts";
---

<!-- Block 1 — Hero Section -->
<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden pt-28 sm:pt-32 pb-16 sm:pb-20 bg-[#ffffff]"
>
  <!-- Soft brand glow behind the headline -->
  <div class="absolute inset-x-0 top-0 h-[70%] hero-radial-glow pointer-events-none"></div>
  <div class="absolute inset-0 grid-bg opacity-[0.35] pointer-events-none"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 w-full">
    <div class="flex flex-col items-center text-center gap-6 sm:gap-8 reveal">
      <!-- Credibility badge -->
      <a
        href="#who-we-are"
        class="attention-pulse inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full bg-[#ffffff] border border-[#ebe9e0] shadow-sm transition-colors hover:border-[#d4e4a8] hover:bg-[#f8f7f3]"
      >
        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"></path>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"></path>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"></path>
        </svg>
        <span class="text-[#161514] text-sm sm:text-base font-semibold tracking-wide">
          Google for Nonprofits Partner
        </span>
      </a>

      <!-- H1 -->
      <h1
        class="text-3xl sm:text-5xl lg:text-6xl font-black leading-[1.06] tracking-tight max-w-4xl text-[#161514]"
      >
        Find out how to hit
        <span class="gradient-text-lime">$10,000/month</span>
        in Google Ad Grant spend — and grow your donations
      </h1>

      <!-- Subheadline -->
      <p class="text-base sm:text-xl lg:text-2xl text-[#52504c] leading-relaxed max-w-2xl">
        Get a free audit and a clear, step-by-step action plan tailored to your
        account.
      </p>

      <!-- CTA -->
      <div class="flex flex-col items-center gap-3 mt-1">
        <a
          href={BOOK_HREF}
          class="btn-primary attention-pulse text-base sm:text-2xl !py-3 sm:!py-4 !px-8 sm:!px-10"
        >
          {CTA_PRIMARY} →
        </a>

        <!-- Supporting text under button -->
        <div
          class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-[#7a7770] text-sm sm:text-base font-medium mt-1"
        >
          <span>2 short calls</span>
          <span class="w-1 h-1 rounded-full bg-[#cfcfcf]"></span>
          <span>No commitment</span>
          <span class="w-1 h-1 rounded-full bg-[#cfcfcf]"></span>
          <span>Actionable plan</span>
        </div>
      </div>

      <!-- Quick stats reinforcing the promise -->
      <div class="grid grid-cols-3 gap-5 sm:gap-10 mt-6 sm:mt-8 w-full max-w-xl">
        {
          [
            { value: "$10K", label: "Monthly grant ceiling" },
            { value: "30 min", label: "Your active time" },
            { value: "Free", label: "Plan yours to keep" },
          ].map((stat) => (
            <div class="text-center">
              <div class="text-2xl sm:text-3xl lg:text-4xl font-black gradient-text mb-1">
                {stat.value}
              </div>
              <div class="text-[#7a7770] text-xs sm:text-sm lg:text-base font-medium">
                {stat.label}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <a
    href="#case-studies"
    aria-label="Scroll to case studies"
    class="absolute bottom-6 left-1/2 -translate-x-1/2 text-[#9a9890] hidden sm:block float-anim"
  >
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
  </a>
</section>
