---
import { BOOK_HREF, CTA_PRIMARY } from "../consts";

// Real promise stats, styled in the Google Ads signature colors
// (blue / yellow / green — the Google Ads logo palette) so the hero reads
// instantly as a Google Ads dashboard.
const adStats = [
  {
    value: "5.18K",
    label: "Clicks",
    bg: "#4285F4",
    fg: "#ffffff",
    stroke: "#ffffff",
    path: "M2 26 C 14 24, 22 28, 34 22 S 56 12, 70 16 S 96 6, 118 8",
  },
  {
    value: "248",
    label: "Conversions",
    bg: "#FBBC05",
    fg: "#3c4043",
    stroke: "#3c4043",
    path: "M2 28 C 14 22, 26 26, 40 20 S 60 22, 74 14 S 100 12, 118 8",
  },
  {
    value: "$9.98K",
    label: "Cost",
    bg: "#34A853",
    fg: "#ffffff",
    stroke: "#ffffff",
    path: "M2 22 C 16 24, 28 20, 42 24 S 60 16, 76 18 S 100 11, 118 10",
  },
];
---

<!-- Block 1 — Hero Section -->
<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16 sm:pt-32 pb-8 sm:pb-20 bg-[#ffffff]"
>
  <!-- Soft brand glow behind the headline -->
  <div
    class="absolute inset-x-0 top-0 h-[70%] hero-radial-glow pointer-events-none"
  >
  </div>
  <div class="absolute inset-0 grid-bg opacity-[0.35] pointer-events-none">
  </div>

  <!-- Floating Google-colored accents (decorative, desktop only) -->
  <div
    class="absolute inset-0 pointer-events-none hidden lg:block"
    aria-hidden="true"
  >
    <span
      class="absolute top-[22%] left-[7%] w-3.5 h-3.5 rounded-full bg-[#4285F4]/70 float-anim"
    ></span>
    <span
      class="absolute top-[34%] right-[9%] w-4 h-4 rounded-sm bg-[#FBBC05]/70 float-anim"
      style="animation-delay:-1.2s"></span>
    <span
      class="absolute bottom-[26%] left-[11%] w-4 h-4 rounded-full bg-[#34A853]/60 float-anim"
      style="animation-delay:-2s"></span>
    <span
      class="absolute top-[16%] right-[16%] w-3 h-3 rounded-full bg-[#EA4335]/60 float-anim"
      style="animation-delay:-0.6s"></span>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 w-full">
    <div class="flex flex-col items-center text-center gap-3 sm:gap-8 reveal">
      <!-- Credibility badge -->
      <a
        href="#who-we-are"
        class="attention-pulse inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full bg-[#ffffff] border border-[#ebe9e0] shadow-sm transition-colors hover:border-[#d4e4a8] hover:bg-[#f8f7f3]"
      >
        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <path
            d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
            fill="#4285F4"></path>
          <path
            d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
            fill="#34A853"></path>
          <path
            d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
            fill="#FBBC05"></path>
          <path
            d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
            fill="#EA4335"></path>
        </svg>
        <span
          class="text-[#161514] text-sm sm:text-base font-semibold tracking-wide"
        >
          Google for Nonprofits Partner
        </span>
      </a>

      <!-- H1 -->
      <h1
        class="text-3xl sm:text-5xl lg:text-6xl font-black leading-[1.06] tracking-tight max-w-4xl text-[#161514]"
      >
        Find out how to hit
        <span class="gradient-text-lime">$10,000/month</span>
        in Google Ad Grant spend — and grow your donations
      </h1>

      <!-- Subheadline -->
      <p
        class="text-base sm:text-xl lg:text-2xl text-[#52504c] leading-relaxed max-w-2xl"
      >
        Get a free audit and a clear, step-by-step action plan tailored to your
        account.
      </p>

      <!-- CTA -->
      <div class="flex flex-col items-center gap-3 mt-1">
        <a
          href={BOOK_HREF}
          class="btn-primary attention-pulse text-base sm:text-2xl !py-3 sm:!py-4 !px-8 sm:!px-10"
        >
          {CTA_PRIMARY} →
        </a>

        <!-- Supporting text under button -->
        <div
          class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-[#7a7770] text-sm sm:text-base font-medium mt-1"
        >
          <span>2 short calls</span>
          <span class="w-1 h-1 rounded-full bg-[#cfcfcf]"></span>
          <span>No commitment</span>
          <span class="w-1 h-1 rounded-full bg-[#cfcfcf]"></span>
          <span>Actionable plan</span>
        </div>
      </div>

      <!-- Google Ads dashboard card — the signature Google Ads visual -->
      <div class="w-full max-w-3xl mt-1 sm:mt-6">
        <div
          class="glass-card rounded-2xl sm:rounded-3xl shadow-[0_20px_50px_rgba(63,80,40,0.10)] overflow-hidden text-left"
        >
          <!-- Card chrome: Google Ads wordmark + live status -->
          <div
            class="flex items-center justify-between gap-3 px-4 sm:px-6 py-3 sm:py-4 border-b border-[#ebe9e0]"
          >
            <div class="flex items-center gap-2.5">
              <svg
                viewBox="-6 4 262 230"
                width="28"
                height="26"
                aria-hidden="true"
                class="shrink-0"
              >
                <path
                  fill="#3C8BD9"
                  d="M85.9,28.6c2.4-6.3,5.7-12.1,10.6-16.8c19.6-19.1,52-14.3,65.3,9.7c10,18.2,20.6,36,30.9,54c17.2,29.9,34.6,59.8,51.6,89.8c14.3,25.1-1.2,56.8-29.6,61.1c-17.4,2.6-33.7-5.4-42.7-21c-15.1-26.3-30.3-52.6-45.4-78.8c-0.3-0.6-0.7-1.1-1.1-1.6c-1.6-1.3-2.3-3.2-3.3-4.9c-6.7-11.8-13.6-23.5-20.3-35.2c-4.3-7.6-8.8-15.1-13.1-22.7c-3.9-6.8-5.7-14.2-5.5-22C83.6,36.2,84.1,32.2,85.9,28.6"
                ></path>
                <path
                  fill="#FABC04"
                  d="M85.9,28.6c-0.9,3.6-1.7,7.2-1.9,11c-0.3,8.4,1.8,16.2,6,23.5C101,82,112,101,122.9,120c1,1.7,1.8,3.4,2.8,5c-6,10.4-12,20.7-18.1,31.1c-8.4,14.5-16.8,29.1-25.3,43.6c-0.4,0-0.5-0.2-0.6-0.5c-0.1-0.8,0.2-1.5,0.4-2.3c4.1-15,0.7-28.3-9.6-39.7c-6.3-6.9-14.3-10.8-23.5-12.1c-12-1.7-22.6,1.4-32.1,8.9c-1.7,1.3-2.8,3.2-4.8,4.2c-0.4,0-0.6-0.2-0.7-0.5c4.8-8.3,9.5-16.6,14.3-24.9C45.5,98.4,65.3,64,85.2,29.7C85.4,29.3,85.7,29,85.9,28.6"
                ></path>
                <path
                  fill="#34A852"
                  d="M11.8,158c1.9-1.7,3.7-3.5,5.7-5.1c24.3-19.2,60.8-5.3,66.1,25.1c1.3,7.3,0.6,14.3-1.6,21.3c-0.1,0.6-0.2,1.1-0.4,1.7c-0.9,1.6-1.7,3.3-2.7,4.9c-8.9,14.7-22,22-39.2,20.9C20,225.4,4.5,210.6,1.8,191c-1.3-9.5,0.6-18.4,5.5-26.6c1-1.8,2.2-3.4,3.3-5.2C11.1,158.8,10.9,158,11.8,158"
                ></path>
                <path
                  fill="#FABC04"
                  d="M11.8,158c-0.4,0.4-0.4,1.1-1.1,1.2c-0.1-0.7,0.3-1.1,0.7-1.6L11.8,158"
                ></path>
                <path
                  fill="#E1C025"
                  d="M81.6,201c-0.4-0.7,0-1.2,0.4-1.7c0.1,0.1,0.3,0.3,0.4,0.4L81.6,201"
                ></path>
              </svg>
              <span
                class="text-[#161514] font-bold text-sm sm:text-base tracking-tight"
              >
                Google <span class="font-medium text-[#52504c]">Ads</span>
              </span>
            </div>
            <span
              class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-[#e6f4ea] text-[#188038] text-xs font-semibold"
            >
              <span class="w-1.5 h-1.5 rounded-full bg-[#34A853]"></span>
              Ad Grant active
            </span>
          </div>

          <!-- Google-colored stat strip -->
          <div class="grid grid-cols-3">
            {
              adStats.map((s) => (
                <div
                  class="relative px-4 py-4 sm:px-5 sm:py-5 flex flex-col gap-3"
                  style={`background:${s.bg}`}
                >
                  <div
                    class="text-xs sm:text-sm font-medium opacity-90"
                    style={`color:${s.fg}`}
                  >
                    {s.label}
                  </div>
                  <div
                    class="text-2xl sm:text-3xl font-black leading-none tracking-tight"
                    style={`color:${s.fg}`}
                  >
                    {s.value}
                  </div>
                  <svg
                    viewBox="0 0 120 34"
                    class="w-full h-6 sm:h-7 mt-0.5"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path
                      d={s.path}
                      stroke={s.stroke}
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </div>
              ))
            }
          </div>
        </div>

        <p
          class="text-center mt-3 text-[#3f5028] text-sm sm:text-base font-bold"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            class="inline-block align-middle mr-1.5 -mt-0.5"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10" fill="#34A853"></circle>
            <path
              d="M17 8.5 10.5 15 7 11.5"
              fill="none"
              stroke="#ffffff"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          Guaranteed results after your audit — that’s our track record
        </p>
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <a
    href="#case-studies"
    aria-label="Scroll to case studies"
    class="absolute bottom-6 left-1/2 -translate-x-1/2 text-[#9a9890] hidden sm:block float-anim"
  >
    <svg
      width="26"
      height="26"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg
    >
  </a>
</section>
