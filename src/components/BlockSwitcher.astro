---
import { SWITCH_BLOCKS } from "../consts";
---

<!--
  Floating block switcher — fulfils the brief's requirement to jump between
  Case Studies / How It Works / Who We Are from any position on the page.
  Appears after the hero; highlights the section currently in view.
-->
<nav
  id="block-switcher"
  class="block-switcher fixed bottom-5 left-1/2 -translate-x-1/2 z-40 px-2 sm:px-2.5"
  aria-label="Jump to section"
>
  <div class="flex flex-col items-center gap-2">
    <div class="flex items-center justify-center gap-2 sm:gap-2.5">
      {
        SWITCH_BLOCKS.map((link) => (
          <a
            href={link.href}
            data-switch={link.href}
            class="switch-pill backdrop-blur-lg px-3.5 sm:px-4 py-2 rounded-full text-[13px] sm:text-sm font-semibold whitespace-nowrap"
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</nav>

<script is:inline>
  (function () {
    const bar = document.getElementById("block-switcher");
    if (!bar) return;
    const links = Array.prototype.slice.call(
      bar.querySelectorAll("[data-switch]"),
    );
    const ids = links.map(function (l) {
      return l.getAttribute("data-switch").slice(1);
    });
    const sections = ids
      .map(function (id) {
        return document.getElementById(id);
      })
      .filter(Boolean);

    function setActive(id) {
      links.forEach(function (l) {
        const on = l.getAttribute("data-switch") === "#" + id;
        // Bright lime pill for the section currently in view.
        l.classList.toggle("is-active", on);
        l.setAttribute("aria-current", on ? "true" : "false");
      });
    }

    // Tap "pop" bounce on each pill.
    var reduceMotion =
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    links.forEach(function (l) {
      l.addEventListener("pointerdown", function () {
        if (reduceMotion) return;
        l.classList.remove("tapped");
        void l.offsetWidth; // restart the animation
        l.classList.add("tapped");
      });
      l.addEventListener("animationend", function () {
        l.classList.remove("tapped");
      });
    });

    // Show the switcher only after the hero scrolls away.
    const hero = document.getElementById("hero");
    function onScroll() {
      const past = hero
        ? window.scrollY > hero.offsetHeight - 120
        : window.scrollY > 600;
      bar.classList.toggle("is-active", past);
    }
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    // Track which section is in view to highlight the matching pill.
    if ("IntersectionObserver" in window && sections.length) {
      const io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) setActive(entry.target.id);
          });
        },
        { threshold: 0.4, rootMargin: "-20% 0px -40% 0px" },
      );
      sections.forEach(function (s) {
        io.observe(s);
      });
    }
  })();
</script>
