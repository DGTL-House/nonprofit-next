---
import { BOOK_HREF, CTA_PRIMARY } from "../consts";

// Block 7 — How It Works
const steps = [
  {
    num: "01",
    title: "Book a Session",
    desc: "Pick a time that works for you. Takes 30 seconds.",
    icon: `<rect width="18" height="18" x="3" y="4" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/><path d="m9 16 2 2 4-4"/>`,
  },
  {
    num: "02",
    title: "30-min Google Meet with a specialist",
    desc: "We review your grant account together, identify exactly what's not working, and tell you what needs to change. No pitch. No pressure.",
    icon: `<path d="M15 10l4.55-2.28A1 1 0 0 1 21 8.6v6.8a1 1 0 0 1-1.45.88L15 14"/><rect width="13" height="10" x="2" y="7" rx="2"/>`,
  },
];
---

<!-- Block 7 — How It Works -->
<section
  id="how-it-works"
  class="relative py-16 sm:py-24 overflow-hidden bg-[#f0eee6]/70"
>
  <div class="relative max-w-5xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16 reveal">
      <p
        class="text-[#3f5028] font-bold uppercase tracking-widest text-xs sm:text-sm mb-4"
      >
        How It Works
      </p>
      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-black text-[#161514] leading-tight mb-4"
      >
        How it works — <span class="gradient-text-lime">2 steps</span>
      </h2>
      <p class="text-[#52504c] text-base sm:text-xl">
        No prep needed. No technical knowledge required. Just show up.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid sm:grid-cols-2 gap-5 reveal-stagger">
      {
        steps.map((s) => (
          <div class="glass-card lift rounded-2xl p-6 sm:p-8 relative">
            <span class="absolute top-6 right-6 text-5xl font-black text-[#aac976]/25 leading-none select-none">
              {s.num}
            </span>
            <div
              class="w-12 h-12 rounded-xl flex items-center justify-center mb-5"
              style="background: linear-gradient(135deg, #aac976, #3f5028); box-shadow: 0 0 20px rgba(170,201,118,0.4);"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#ffffff"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={s.icon}
              />
            </div>
            <h3 class="text-[#161514] font-bold text-lg sm:text-xl mb-2.5 max-w-[16rem]">
              {s.title}
            </h3>
            <p class="text-[#52504c] text-sm sm:text-base leading-relaxed">
              {s.desc}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Note under steps -->
    <div class="mt-6 flex justify-center reveal">
      <div class="urgency-box inline-flex items-center gap-2.5 px-5 py-3">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#3f5028"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><circle cx="12" cy="12" r="10"></circle><polyline
            points="12 6 12 12 16 14"></polyline></svg
        >
        <span class="text-[#161514] text-sm sm:text-base font-medium">
          Your active time: <strong class="text-[#3f5028]">30 minutes.</strong> We
          handle the rest.
        </span>
      </div>
    </div>

    <!-- Differentiator callout -->
    <div class="mt-10 reveal">
      <div
        class="rounded-3xl bg-[#161514] text-[#f8f7f3] p-7 sm:p-10 relative overflow-hidden"
      >
        <div
          class="absolute top-0 right-0 w-72 h-72 bg-[#aac976]/20 rounded-full blur-[120px] pointer-events-none"
        >
        </div>
        <div class="relative">
          <div
            class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#aac976]/15 text-[#c4ed82] text-xs font-bold uppercase tracking-wide mb-4"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.4"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><polyline points="20 6 9 17 4 12"></polyline></svg
            >
            Not another template PDF
          </div>
          <p class="text-[#f5f4f0] text-base sm:text-xl leading-relaxed">
            Most audits out there are automated template reports — you get a PDF
            and figure it out yourself. We do it differently:
            <span class="text-[#c4ed82] font-semibold"
              >a real specialist meets with you</span
            >, reviews your specific account, and gives you an honest assessment
            based on your organisation, your audience, and your goals. Because
            the same numbers can mean very different things for an education
            nonprofit versus a refugee support organisation.
          </p>
        </div>
      </div>
    </div>

    <div class="flex justify-center mt-12 reveal">
      <a
        href={BOOK_HREF}
        class="btn-primary text-base sm:text-2xl !py-3 sm:!py-4 !px-8 sm:!px-10"
      >
        {CTA_PRIMARY} →
      </a>
    </div>
  </div>
</section>
