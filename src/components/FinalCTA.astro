---
import { BOOK_CALL } from "../consts";

// Offer economics — savings is derived so the three numbers can never drift.
const PRICE_REGULAR = 800;
const PRICE_NOW = 49;
const SAVINGS = PRICE_REGULAR - PRICE_NOW;

const guarantees = [
  { icon: "🎯", title: "Free", desc: "No hidden costs, ever" },
  { icon: "🤝", title: "No strings", desc: "Walk away anytime" },
  { icon: "📋", title: "Yours to keep", desc: "Actionable plan you own" },
  { icon: "🏛️", title: "Nonprofit-first", desc: "Built for your world" },
];
---

<!-- Block 8 — Final CTA + Urgency -->
<section
  class="relative pt-8 sm:pt-12 pb-16 sm:pb-24 overflow-hidden bg-[#ffffff]"
>
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[480px] bg-[#aac976]/15 rounded-full blur-[170px] pointer-events-none"
  >
  </div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <div class="reveal">
      <!-- #book anchor lives here so CTAs land right on the offer card, just
           below the header, instead of deep inside the section. -->
      <div id="book" class="scroll-mt-4 sm:scroll-mt-6"></div>

      <!-- Offer card -->
      <div
        id="offer-card"
        class="glass-card rounded-3xl px-5 py-7 sm:px-10 sm:py-10 shadow-[0_20px_50px_rgba(63,80,40,0.10)]"
      >
        <!-- 1 — Countdown -->
        <div
          class="inline-flex items-center gap-2 text-[#52504c] text-xs sm:text-sm font-medium"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="shrink-0"
            aria-hidden="true"
            ><circle cx="12" cy="12" r="10"></circle><polyline
              points="12 6 12 12 16 14"></polyline></svg
          >
          <span>Offer expires in</span>
          <span
            id="offer-timer"
            class="font-mono font-bold text-[#161514] bg-[#f0eee6] rounded-md px-2 py-0.5 tabular-nums"
            >03:00:00</span
          >
        </div>

        <!-- 2 — This month's price -->
        <div class="mt-5 flex items-baseline justify-center gap-2 sm:gap-3">
          <span class="text-[#52504c] text-base sm:text-2xl font-medium">
            This month:
          </span>
          <span
            class="text-5xl sm:text-7xl font-bold leading-none tracking-tight text-[#161514]"
          >
            ${PRICE_NOW}
          </span>
        </div>

        <!-- 3 — Savings accent -->
        <p class="mt-2.5 text-[#188038] text-base sm:text-xl font-bold">
          You save ${SAVINGS}.
        </p>

        <!-- 4 — Value anchor -->
        <p class="mt-3 text-[#52504c] text-sm sm:text-lg leading-relaxed">
          A senior specialist audit normally costs
          <span class="line-through text-[#9a9890]">${PRICE_REGULAR}</span>.
        </p>

        <!-- 5 — Full-width CTA -->
        <a
          href={BOOK_CALL}
          class="btn-primary attention-pulse w-full mt-6 text-base sm:text-2xl !py-3.5 sm:!py-4"
        >
          Schedule a Call — It's Free →
        </a>

        <!-- 6 — Live scarcity line, right under the CTA -->
        <div class="mt-3">
          <span
            class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-bold uppercase tracking-[0.18em] text-[#b33d27]"
          >
            <span class="relative flex h-2.5 w-2.5 shrink-0">
              <span
                class="absolute inline-flex h-full w-full rounded-full bg-[#b33d27] opacity-50 animate-ping"
              ></span>
              <span
                class="relative inline-flex rounded-full h-2.5 w-2.5 bg-[#b33d27]"
              ></span>
            </span>
            <span aria-live="polite">
              <span id="spots-count" class="spot-number">3</span> spots left in
              <span id="spots-month">July</span>
            </span>
          </span>
        </div>
      </div>

      <!-- Guarantee recap cards -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 mt-8">
        {
          guarantees.map((g) => (
            <div class="glass-card lift rounded-2xl p-4 sm:p-5 text-center">
              <div class="text-3xl sm:text-4xl mb-2" aria-hidden="true">
                {g.icon}
              </div>
              <div class="text-[#161514] font-bold text-sm sm:text-base leading-tight">
                {g.title}
              </div>
              <div class="text-[#7a7770] text-xs sm:text-sm mt-1 leading-snug">
                {g.desc}
              </div>
            </div>
          ))
        }
      </div>

      <!-- Scarcity + waitlist notes -->
      <div class="mt-10 max-w-xl mx-auto space-y-3">
        <p class="text-[#9a9890] text-xs sm:text-sm leading-relaxed">
          Each audit takes 8–10 hours of senior analyst time. To keep the
          quality high, we cap the number.
        </p>
        <div class="urgency-box px-5 py-3">
          <p class="text-[#52504c] text-sm">
            If all spots are taken — we'll add you to the waitlist for next
            month.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var card = document.getElementById("offer-card");
    var countEl = document.getElementById("spots-count");
    var monthEl = document.getElementById("spots-month");
    var timerEl = document.getElementById("offer-timer");
    if (!card) return;

    var reduce =
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    /* ---------- Live month ---------- */
    try {
      if (monthEl) {
        monthEl.textContent = new Date().toLocaleString("en-US", {
          month: "long",
        });
      }
    } catch (e) {}

    /* ---------- Spots counter: ticks down while you read ---------- */
    if (countEl) {
      var left = 3; // spots shown on arrival
      var FLOOR = 1; // never bottoms out at 0
      countEl.textContent = left;

      function decrement() {
        if (left <= FLOOR) return;
        left--;
        countEl.textContent = left;
        if (!reduce) {
          countEl.classList.remove("pop");
          void countEl.offsetWidth; // restart the animation
          countEl.classList.add("pop");
        }
      }

      var started = false;
      function startCountdown() {
        if (started) return;
        started = true;
        setTimeout(decrement, 2200); // 3 → 2 shortly after arriving
        setTimeout(decrement, 2200 + 26000); // 2 → 1 a while later
      }

      if ("IntersectionObserver" in window) {
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                startCountdown();
                io.disconnect();
              }
            });
          },
          { threshold: 0.4 },
        );
        io.observe(card);
      } else {
        startCountdown();
      }
    }

    /* ---------- Offer countdown timer ----------
       The deadline is persisted so it keeps running across reloads instead of
       resetting to a full window every visit. */
    if (timerEl) {
      var KEY = "dgtl-offer-deadline";
      var WINDOW_MS = 3 * 60 * 60 * 1000; // 3 hours
      var deadline;

      try {
        deadline = parseInt(window.localStorage.getItem(KEY), 10);
      } catch (e) {}

      var remaining = deadline - Date.now();
      if (
        !deadline ||
        isNaN(deadline) ||
        remaining <= 0 ||
        remaining > WINDOW_MS
      ) {
        deadline = Date.now() + WINDOW_MS;
        try {
          window.localStorage.setItem(KEY, String(deadline));
        } catch (e) {}
      }

      var ticker;
      function pad(n) {
        return n < 10 ? "0" + n : "" + n;
      }
      function tick() {
        var ms = deadline - Date.now();
        if (ms < 0) ms = 0;
        var s = Math.floor(ms / 1000);
        timerEl.textContent =
          pad(Math.floor(s / 3600)) +
          ":" +
          pad(Math.floor((s % 3600) / 60)) +
          ":" +
          pad(s % 60);
        if (ms <= 0 && ticker) clearInterval(ticker);
      }
      tick();
      ticker = setInterval(tick, 1000);
    }
  })();
</script>
