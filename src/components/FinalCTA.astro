---
import { BOOK_HREF } from "../consts";

const guarantees = [
  { icon: "🎯", title: "Free", desc: "No hidden costs, ever" },
  { icon: "🤝", title: "No strings", desc: "Walk away anytime" },
  { icon: "📋", title: "Yours to keep", desc: "Actionable plan you own" },
  { icon: "🏛️", title: "Nonprofit-first", desc: "Built for your world" },
];
---

<!-- Block 8 — Final CTA + Urgency -->
<section
  class="relative pt-8 sm:pt-12 pb-16 sm:pb-24 overflow-hidden bg-[#ffffff]"
>
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[480px] bg-[#aac976]/15 rounded-full blur-[170px] pointer-events-none"
  >
  </div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <div class="reveal">
      <!-- Live scarcity counter — spots deplete while you read the page.
           #book anchor lives here so CTAs land right on the counter, just
           below the header, instead of ~190px into the section. The negative
           scroll-margin trims the global 96px scroll-padding down to a snug
           header clearance. -->
      <div id="book" class="scroll-mt-4 sm:scroll-mt-6"></div>
      <div
        id="spots-widget"
        class="inline-flex flex-col items-center mb-7 sm:mb-9"
      >
        <span
          class="inline-flex items-center gap-2 text-[11px] sm:text-xs font-bold uppercase tracking-[0.18em] text-[#b33d27]"
        >
          <span class="relative flex h-2.5 w-2.5">
            <span
              class="absolute inline-flex h-full w-full rounded-full bg-[#b33d27] opacity-50 animate-ping"
            ></span>
            <span
              class="relative inline-flex rounded-full h-2.5 w-2.5 bg-[#b33d27]"
            ></span>
          </span>
          <span id="spots-label">Spots left this month</span>
        </span>

        <!-- 10 dots: filled = still available, dimmed = already taken -->
        <div
          id="spots-dots"
          class="flex items-center gap-1.5 sm:gap-2 mt-4"
          aria-hidden="true"
        >
        </div>

        <div class="mt-3 flex flex-col items-center" aria-live="polite">
          <span
            id="spots-number"
            class="spot-number text-6xl sm:text-7xl font-black leading-none text-[#3f5028]"
            >4</span
          >
          <span class="mt-2 text-[#52504c] text-sm sm:text-base font-semibold">
            of <span class="text-[#161514] font-bold">10</span> spots remaining
          </span>
        </div>
      </div>

      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-black text-[#161514] leading-tight mb-5"
      >
        Find out in 30 minutes what's stopping your grant from
        <span class="gradient-text-lime">working</span>
      </h2>

      <p
        class="text-[#52504c] text-base sm:text-xl leading-relaxed max-w-2xl mx-auto mb-6"
      >
        We take on only <strong class="text-[#161514]"
          >10 audits per month</strong
        > — because quality comes first. It's free, and the plan is yours to keep.
      </p>

      <!-- CTA -->
      <div class="flex flex-col items-center gap-3 mb-8">
        <a
          href={BOOK_HREF}
          class="btn-primary attention-pulse text-base sm:text-2xl !py-3.5 sm:!py-4 !px-8 sm:!px-12"
        >
          Schedule a Call →
        </a>
        <div
          class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-[#7a7770] text-sm sm:text-base font-medium"
        >
          <span>No pressure</span>
          <span class="w-1 h-1 rounded-full bg-[#cfcfcf]"></span>
          <span>No commitment</span>
          <span class="w-1 h-1 rounded-full bg-[#cfcfcf]"></span>
          <span>2 short calls</span>
        </div>
      </div>

      <!-- Guarantee recap cards -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 mb-8">
        {
          guarantees.map((g) => (
            <div class="glass-card lift rounded-2xl p-4 sm:p-5 text-center">
              <div class="text-3xl sm:text-4xl mb-2" aria-hidden="true">
                {g.icon}
              </div>
              <div class="text-[#161514] font-bold text-sm sm:text-base leading-tight">
                {g.title}
              </div>
              <div class="text-[#7a7770] text-xs sm:text-sm mt-1 leading-snug">
                {g.desc}
              </div>
            </div>
          ))
        }
      </div>

      <!-- Scarcity + waitlist notes -->
      <div class="mt-10 max-w-xl mx-auto space-y-3">
        <p class="text-[#9a9890] text-xs sm:text-sm leading-relaxed">
          Each audit takes 8–10 hours of senior analyst time. To keep the
          quality high, we cap the number.
        </p>
        <div class="urgency-box px-5 py-3">
          <p class="text-[#52504c] text-sm">
            If all spots are taken — we'll add you to the waitlist for next
            month.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var widget = document.getElementById("spots-widget");
    var numEl = document.getElementById("spots-number");
    var dotsEl = document.getElementById("spots-dots");
    var labelEl = document.getElementById("spots-label");
    if (!widget || !numEl || !dotsEl) return;

    var TOTAL = 10;
    var left = 4; // spots shown when the visitor arrives
    var FLOOR = 2; // countdown stops here so it never bottoms out at 0

    // Live month name in the label.
    try {
      var m = new Date().toLocaleString("en-US", { month: "long" });
      if (labelEl) labelEl.textContent = "Spots left in " + m;
    } catch (e) {}

    // Build the 10 dots; the first `left` are available, the rest taken.
    var dots = [];
    for (var i = 0; i < TOTAL; i++) {
      var d = document.createElement("span");
      d.className = "spot-dot" + (i >= left ? " is-taken" : "");
      dotsEl.appendChild(d);
      dots.push(d);
    }

    var reduce =
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function decrement() {
      if (left <= FLOOR) return;
      left--;
      var d = dots[left]; // the dot that just got claimed
      if (d) {
        if (reduce) {
          d.classList.add("is-taken");
        } else {
          d.classList.add("just-taken");
          setTimeout(function () {
            d.classList.remove("just-taken");
            d.classList.add("is-taken");
          }, 700);
        }
      }
      numEl.textContent = left;
      if (!reduce) {
        numEl.classList.remove("pop");
        void numEl.offsetWidth; // restart the animation
        numEl.classList.add("pop", "flash-red");
        setTimeout(function () {
          numEl.classList.remove("flash-red");
        }, 700);
      }
    }

    // Start the countdown only once the block is actually seen.
    var started = false;
    function start() {
      if (started) return;
      started = true;
      setTimeout(decrement, 2200); // 8 → 7 a couple seconds after arriving
      setTimeout(decrement, 2200 + 26000); // 7 → 6 a while later
    }

    if ("IntersectionObserver" in window) {
      var io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              start();
              io.disconnect();
            }
          });
        },
        { threshold: 0.5 },
      );
      io.observe(widget);
    } else {
      start();
    }
  })();
</script>
