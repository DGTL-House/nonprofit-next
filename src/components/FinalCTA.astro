---
import { BOOK_CALL } from "../consts";

// Offer economics — savings is derived so the three numbers can never drift.
const PRICE_REGULAR = 800;
const PRICE_NOW = 49;
const SAVINGS = PRICE_REGULAR - PRICE_NOW;

const guarantees = [
  { icon: "🤝", title: "No strings", desc: "Walk away anytime" },
  { icon: "📋", title: "Yours to keep", desc: "Actionable plan you own" },
  { icon: "🏛️", title: "Nonprofit-first", desc: "Built for your world" },
];
---

<!-- Block 8 — Final CTA + Urgency -->
<section
  class="relative pt-8 sm:pt-12 pb-16 sm:pb-24 overflow-hidden bg-[#ffffff]"
>
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[480px] bg-[#aac976]/15 rounded-full blur-[170px] pointer-events-none"
  >
  </div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <div class="reveal">
      <!-- #book anchor lives here so CTAs land right on the offer, just below
           the header, instead of deep inside the section. -->
      <div id="book" class="scroll-mt-4 sm:scroll-mt-6"></div>

      <!-- Heading -->
      <h2
        class="text-2xl sm:text-4xl lg:text-5xl font-black text-[#161514] leading-tight"
      >
        Find out in 30 minutes what's stopping your grant from
        <span class="gradient-text-lime">working</span>
      </h2>
      <p
        class="mt-3 sm:mt-4 text-[#52504c] text-sm sm:text-lg leading-relaxed max-w-xl mx-auto"
      >
        We take only <strong class="text-[#161514]">10 audits per month</strong>
        — because quality comes first.
      </p>

      <!-- Offer card -->
      <div
        id="offer-card"
        class="glass-card rounded-3xl px-5 py-7 sm:px-10 sm:py-9 mt-7 sm:mt-9 shadow-[0_20px_50px_rgba(63,80,40,0.10)]"
      >
        <!-- 1 — Savings badge -->
        <span
          class="inline-flex items-center px-3.5 py-1.5 rounded-full bg-[#eaf6cc] text-[#3f5028] text-sm sm:text-base font-bold"
        >
          Save ${SAVINGS}
        </span>

        <!-- 2 — Price: old (struck) + new (hero) -->
        <div
          class="mt-4 flex items-center justify-center gap-3 sm:gap-4 flex-wrap"
        >
          <span
            class="text-2xl sm:text-4xl font-bold text-[#9a9890] line-through"
          >
            ${PRICE_REGULAR}
          </span>
          <span
            class="text-6xl sm:text-7xl font-bold leading-none tracking-tight text-[#161514]"
          >
            ${PRICE_NOW}
          </span>
        </div>

        <!-- 3 — Countdown bar -->
        <div
          class="mt-5 flex items-center justify-center gap-2 sm:gap-3 rounded-2xl border border-[#b33d27]/15 bg-[#b33d27]/[0.07] px-3 py-3"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#b33d27"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="shrink-0"
            aria-hidden="true"
            ><circle cx="12" cy="12" r="10"></circle><polyline
              points="12 6 12 12 16 14"></polyline></svg
          >
          <span class="text-[#52504c] text-sm sm:text-base font-medium">
            Offer ends in
          </span>
          <span
            class="font-mono font-bold text-[#161514] text-base sm:text-lg tabular-nums inline-flex items-center gap-1 sm:gap-1.5"
          >
            <span id="t-h">03</span>
            <span class="text-[#9a9890]">:</span>
            <span id="t-m">00</span>
            <span class="text-[#9a9890]">:</span>
            <span id="t-s">00</span>
          </span>
        </div>

        <!-- 4 — CTA with its reassurance inside the pill -->
        <a
          href={BOOK_CALL}
          class="btn-primary attention-pulse w-full mt-5 !flex-col !gap-1 !py-4 sm:!py-5"
        >
          <span class="text-xl sm:text-3xl font-bold leading-none">
            Schedule a Call
          </span>
          <span class="text-xs sm:text-sm font-medium opacity-75">
            No commitment · 30 min
          </span>
        </a>

        <!-- 5 — Live scarcity, right under the CTA -->
        <div
          class="mt-3.5 inline-flex items-center gap-2 text-[#b33d27] text-sm sm:text-base font-bold"
        >
          <span aria-hidden="true">⚠️</span>
          <span aria-live="polite">
            Limited availability: <span id="spots-count" class="spot-number"
              >2</span
            > spots left
          </span>
        </div>
      </div>

      <!-- Guarantee recap cards — centred, wraps cleanly for any count -->
      <div class="mt-8 flex flex-wrap justify-center gap-3 sm:gap-4">
        {
          guarantees.map((g) => (
            <div class="glass-card lift rounded-2xl p-4 sm:p-5 text-center w-[calc(50%-0.375rem)] sm:w-48">
              <div class="text-3xl sm:text-4xl mb-2" aria-hidden="true">
                {g.icon}
              </div>
              <div class="text-[#161514] font-bold text-sm sm:text-base leading-tight">
                {g.title}
              </div>
              <div class="text-[#7a7770] text-xs sm:text-sm mt-1 leading-snug">
                {g.desc}
              </div>
            </div>
          ))
        }
      </div>

      <!-- Scarcity + waitlist notes -->
      <div class="mt-10 max-w-xl mx-auto space-y-3">
        <p class="text-[#9a9890] text-xs sm:text-sm leading-relaxed">
          Each audit takes 8–10 hours of senior analyst time. To keep the
          quality high, we cap the number.
        </p>
        <div class="urgency-box px-5 py-3">
          <p class="text-[#52504c] text-sm">
            If all spots are taken — we'll add you to the waitlist for next
            month.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var card = document.getElementById("offer-card");
    var countEl = document.getElementById("spots-count");
    var hEl = document.getElementById("t-h");
    var mEl = document.getElementById("t-m");
    var sEl = document.getElementById("t-s");
    if (!card) return;

    var reduce =
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    /* ---------- Spots counter: ticks down while you read ---------- */
    if (countEl) {
      var left = 3; // spots shown on arrival
      var FLOOR = 1; // never bottoms out at 0
      countEl.textContent = left;

      function decrement() {
        if (left <= FLOOR) return;
        left--;
        countEl.textContent = left;
        if (!reduce) {
          countEl.classList.remove("pop");
          void countEl.offsetWidth; // restart the animation
          countEl.classList.add("pop");
        }
      }

      var started = false;
      function startCountdown() {
        if (started) return;
        started = true;
        setTimeout(decrement, 2200); // 3 → 2 shortly after arriving
        setTimeout(decrement, 2200 + 26000); // 2 → 1 a while later
      }

      if ("IntersectionObserver" in window) {
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                startCountdown();
                io.disconnect();
              }
            });
          },
          { threshold: 0.4 },
        );
        io.observe(card);
      } else {
        startCountdown();
      }
    }

    /* ---------- Offer countdown timer ----------
       The deadline is persisted so it keeps running across reloads instead of
       resetting to a full window every visit. */
    if (hEl && mEl && sEl) {
      var KEY = "dgtl-offer-deadline";
      var WINDOW_MS = 3 * 60 * 60 * 1000; // 3 hours
      var deadline;

      try {
        deadline = parseInt(window.localStorage.getItem(KEY), 10);
      } catch (e) {}

      var remaining = deadline - Date.now();
      if (
        !deadline ||
        isNaN(deadline) ||
        remaining <= 0 ||
        remaining > WINDOW_MS
      ) {
        deadline = Date.now() + WINDOW_MS;
        try {
          window.localStorage.setItem(KEY, String(deadline));
        } catch (e) {}
      }

      var ticker;
      function pad(n) {
        return n < 10 ? "0" + n : "" + n;
      }
      function tick() {
        var ms = deadline - Date.now();
        if (ms < 0) ms = 0;
        var s = Math.floor(ms / 1000);
        hEl.textContent = pad(Math.floor(s / 3600));
        mEl.textContent = pad(Math.floor((s % 3600) / 60));
        sEl.textContent = pad(s % 60);
        if (ms <= 0 && ticker) clearInterval(ticker);
      }
      tick();
      ticker = setInterval(tick, 1000);
    }
  })();
</script>
