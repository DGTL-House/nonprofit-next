---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Google Ad Grants Audit — Hit $10K/Month | DGTL House",
  description = "Get a Google Ad Grants audit and a clear, step-by-step plan to hit the full $10,000/month grant spend — and grow your nonprofit's donations.",
  image = "/og-image.webp",
} = Astro.props;

// Build absolute URLs from the configured `site` so canonical/OG are correct
// in any environment. Falls back gracefully when `site` is unset (dev).
const siteUrl = Astro.site ?? new URL("https://grants.dgtl-house.com");
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = new URL(image, siteUrl).href;

const orgLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "DGTL House",
  url: siteUrl.href,
  logo: new URL("/nonprofit-logo.svg", siteUrl).href,
  image: ogImage,
  description:
    "Google Ad Grants audits for nonprofits. A specialist reviews your account and gives you a clear, step-by-step action plan to reach the full $10,000/month grant spend.",
  email: "nonprofit@dgtl-house.com",
  telephone: "+12245848401",
  address: {
    "@type": "PostalAddress",
    streetAddress: "1635 Eagle Grove Ct.",
    addressLocality: "Wheeling",
    addressRegion: "IL",
    postalCode: "60090",
    addressCountry: "US",
  },
  areaServed: "US",
  knowsAbout: [
    "Google Ad Grants",
    "Nonprofit Marketing",
    "Google Ads",
    "Google Ad Grants Audit",
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Google Ad Grants Services",
    itemListElement: [
      {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD",
        itemOffered: {
          "@type": "Service",
          name: "Google Ad Grants Account Audit",
          description:
            "A 30-minute specialist review of your Google Ad Grants account plus a written action plan, no commitment.",
        },
      },
    ],
  },
};

const siteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "DGTL House — Google Ad Grants Audit",
  url: siteUrl.href,
  inLanguage: "en-US",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Mark JS available before paint so reveal animations only arm with JS. -->
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="DGTL House" />
    <meta
      name="keywords"
      content="Google Ad Grants audit, Google Ad Grants audit, nonprofit Google Ads, $10000 grant, Google for Nonprofits, Ad Grants management, nonprofit marketing, DGTL House"
    />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1"
    />
    <meta name="format-detection" content="telephone=no" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <!-- Favicons + PWA -->
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#ffffff" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DGTL House" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:image:width" content="1840" />
    <meta property="og:image:height" content="971" />
    <meta
      property="og:image:alt"
      content="DGTL House — Google Ad Grants audit for nonprofits"
    />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta
      name="twitter:image:alt"
      content="DGTL House — Google Ad Grants audit for nonprofits"
    />

    <!-- Structured data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(orgLd)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(siteLd)}
    />

    <!-- Fonts —
         Lexend (body) is self-hosted and preloaded: it's on the critical render
         path, so no third-party round-trip. Neue Montreal (display) loads async
         from Fontshare and swaps in over the Lexend fallback, never blocking
         first paint. -->
    <link
      rel="preload"
      href="/fonts/lexend-var.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=neue-montreal@500,700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://api.fontshare.com/v2/css?f[]=neue-montreal@500,700&display=swap"
      />
    </noscript>
  </head>
  <body class="min-h-screen bg-[#ffffff]">
    <slot />

    <!-- Global scroll-reveal: replaces framer-motion `fadeUp`/stagger from the
         reference project with a dependency IntersectionObserver. -->
    <script is:inline>
      (function () {
        const reduce = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;
        const targets = document.querySelectorAll(".reveal, .reveal-stagger");
        if (reduce || !("IntersectionObserver" in window)) {
          targets.forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -40px 0px" },
        );
        targets.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
