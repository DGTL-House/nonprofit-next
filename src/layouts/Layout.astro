---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Free Google Ad Grants Audit — Hit $10K/Month | DGTL House",
  description = "Get a free Google Ad Grants audit and a clear, step-by-step action plan tailored to your account. Find out how to hit $10,000/month in grant spend — and grow your donations.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="DGTL House" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="format-detection" content="telephone=no" />

    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <meta name="theme-color" content="#ffffff" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DGTL House" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts: Lexend (body) + Neue Montreal (display), matching the reference site -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700;800&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=neue-montreal@500,700&display=swap"
    />
  </head>
  <body class="min-h-screen bg-[#ffffff]">
    <slot />

    <!-- Global scroll-reveal: replaces framer-motion `fadeUp`/stagger from the
         reference project with a dependency-free IntersectionObserver. -->
    <script is:inline>
      (function () {
        const reduce = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;
        const targets = document.querySelectorAll(".reveal, .reveal-stagger");
        if (reduce || !("IntersectionObserver" in window)) {
          targets.forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -40px 0px" },
        );
        targets.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
